{
  "name": "@loomic/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.3.0",
    "@loomic/shared": "workspace:*",
    "@supabase/supabase-js": "^2.57.0",
    "deepagents": "^1.8.4",
    "fastify": "^5.2.1",
    "jose": "^6.2.2",
    "langchain": "^1.2.36",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "undici": "^7.24.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@loomic/config": "workspace:*",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "node ../../scripts/validate-foundation-app.mjs build",
    "predev": "pnpm --filter @loomic/shared build",
    "dev": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts & node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & wait",
    "dev:server": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts",
    "dev:worker": "node --watch --env-file=../../.env.local --import tsx ./src/worker.ts",
    "worker": "node --env-file=../../.env.local --import tsx ./src/worker.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
