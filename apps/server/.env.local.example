# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-password@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_PROJECT_ID=your-project-id

# AI
OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1  # optional, for custom endpoints

# Image Generation
# REPLICATE_API_TOKEN=your-replicate-token  # optional, enables image generation

# Google Fonts (required for brand kit font picker)
GOOGLE_FONTS_API_KEY=your-google-fonts-api-key

# TTS (optional)
# VOLCES_API_KEY=your-volces-key
# VOLCES_BASE_URL=https://...

# Worker (optional)
# WORKER_POLL_INTERVAL_MS=2000
# WORKER_MAX_BATCH_SIZE=5
